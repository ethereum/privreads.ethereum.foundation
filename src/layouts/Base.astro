---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Private Reads — Exploring privacy-preserving technologies for Ethereum.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      // Apply theme before render to prevent flash
      (function() {
        try { var t = localStorage.getItem('theme') || 'light'; } catch(e) { var t = 'light'; }
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — Private Reads</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} — Private Reads`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Private Reads" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} — Private Reads`} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,400&family=JetBrains+Mono:wght@400;500;700&family=Cormorant+Garamond:ital,wght@1,600&display=swap" rel="stylesheet" />
  </head>

  <body>
    <Nav />

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-brand">Private Reads &mdash; Ethereum Foundation</span>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href={`${base}/workstreams`}>Workstreams</a>
          <a href={`${base}/code`}>Code</a>
          <a href={`${base}/docs`}>Docs</a>
          <a href={`${base}/feed`}>Feed</a>
          <a href={`${base}/about`}>About</a>
        </nav>
        <!-- TODO: re-enable once we have team handles
        <div class="footer-icons">
          <a href="https://github.com/0xalizk" title="GitHub" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://x.com/0xalizk" title="Twitter" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="mailto:privreads@ethereum.org" title="Email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>
        -->
      </div>
    </footer>
  </body>
</html>

<style>
  main {
    min-height: calc(100vh - var(--nav-height) - 80px);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    background: var(--bg);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    font-size: 0.82rem;
  }

  .footer-brand {
    color: var(--text-dim);
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
  }
  .footer-nav a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .footer-nav a:hover { color: var(--text); }

  .footer-icons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .footer-icons a {
    color: var(--text-dim);
    display: flex;
    transition: color 0.2s var(--ease);
  }
  .footer-icons a:hover { color: var(--text); }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
