---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const workstreams = [
  {
    icon: '\u{1F353}',
    title: 'PIR for Ethereum State',
    description: 'Scalable obliviousness primitives ensuring servers cannot learn what clients read. Sharded across data types, each served by a tailored cryptographic engine.',
    href: `${base}/workstreams/pir`,
  },
  {
    icon: '\u{1F351}',
    title: 'TorJS / Embedded Arti',
    description: 'Network-level anonymization via Tor in the browser. Arti compiled to WASM with a fetch()-compatible API for wallets and frontends.',
    href: `${base}/workstreams/torjs`,
  },
  {
    icon: '\u{1F352}',
    title: 'Verifiable UBT',
    description: 'Universal Binary Trie is the future, but we can begin to enjoy its many benefits today, with a proof of its equivalence to mainnet MPT thanks to zkVMs. We use it for PIR, but invite others to begin adopting UBT-enabled nodes we are working on.',
    href: `${base}/workstreams/ubt`,
  },
  {
    icon: '\u{1F34B}',
    title: 'Research',
    description: 'Open problems driving the next generation of privacy-preserving reads: PIR for Merkle trees, DEPIR, delegated hints via FHE/MPC, GPU-optimized stateless schemes, and more.',
    href: `${base}/workstreams/research`,
  },
];
---

<Base title="Workstreams" description="Overview of Private Reads workstreams: PIR, TorJS, and Verifiable UBT.">
  <section class="section">
    <div class="container">
      <h1>Workstreams</h1>
      <p class="subtitle">
        See also:
        <a href={`${base}/feed?type=Monthly+Update`}>monthly updates</a>
        and
        <a href={`${base}/feed?type=Quarterly+Wrap-up`}>quarterly wrap-ups</a>
      </p>

      <div class="grid grid--2">
        {workstreams.map((ws) => (
          <a href={ws.href} class="card ws-card">
            <h3><span class="ws-icon">{ws.icon}</span> {ws.title}</h3>
            <p>{ws.description}</p>

          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 560px;
    margin-bottom: 2rem;
  }
  .ws-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 2px solid transparent;
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .ws-card:hover {
    color: inherit;
    border-bottom-color: var(--link);
    background: var(--bg-card-hover);
  }
  .ws-card h3 { font-size: 1.15rem; }
  .ws-icon { margin-right: 0.3rem; }
  .ws-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 0;
    flex-grow: 1;
  }
</style>
