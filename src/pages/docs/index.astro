---
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Docs" description="Technical documentation from the Private Reads team.">
  <section class="section">
    <div class="container">
      <h1>Docs</h1>
      <div class="docs-grid">
        <a href="https://0xalizk.github.io/PIR-Eng-Notes" class="doc-tile" target="_blank" rel="noopener noreferrer">
          <div class="doc-tile-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h2>PIR Benchmarking</h2>
          <p>Performance data for 31 single-server PIR schemes — communication cost, server/client time, throughput, and Pareto frontiers.</p>
          <span class="doc-tile-link">0xalizk.github.io/PIR-Eng-Notes &nearr;</span>
        </a>
        <a href={`${base}/docs/torjs`} class="doc-tile">
          <div class="doc-tile-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h2>Onion Routing with TorJS</h2>
          <p>How tor-js works — architecture, layers, the fetch() flow, WASM constraints, the gateway, and how to use it in your dApp.</p>
          <span class="doc-tile-link">Read docs &rarr;</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .doc-tile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-card);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .doc-tile:hover {
    color: inherit;
    border-color: var(--border-hover);
    box-shadow: 0 4px 16px var(--shadow-card);
    transform: translateY(-2px);
  }
  .doc-tile-icon {
    color: var(--purple);
    margin-bottom: 0.25rem;
  }
  .doc-tile h2 {
    font-size: 1.3rem;
    margin: 0;
  }
  .doc-tile p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0;
    flex-grow: 1;
  }
  .doc-tile-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--link);
    margin-top: 0.5rem;
  }
  .doc-tile:hover .doc-tile-link { color: var(--link-hover); }

  @media (max-width: 640px) {
    .docs-grid { grid-template-columns: 1fr; }
  }
</style>
