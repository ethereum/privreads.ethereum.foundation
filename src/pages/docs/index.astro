---
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Docs" description="Technical documentation from the Private Reads team.">
  <section class="section">
    <div class="container">
      <h1>Docs</h1>
      <div class="docs-grid">
        <a href={`${base}/docs/pir-benchmarks`} class="doc-tile">
          <div class="doc-tile-icon" style="font-size: 1.75rem;">&#127822;</div>
          <h2>PIR Benchmarking</h2>
          <p>Comparative benchmarks of PIR schemes based on data reported, replicated by us, and independently bench'd using unified test vectors.</p>
          <span class="doc-tile-link">View benchmarks &rarr;</span>
        </a>
        <a href={`${base}/docs/torjs`} class="doc-tile">
          <div class="doc-tile-icon" style="font-size: 1.75rem;">&#127819;</div>
          <h2>Onion Routing with TorJS</h2>
          <p>Integrate onion routing in your wallet, SDK, frontend, or dApp.</p>
          <span class="doc-tile-link">Read docs &rarr;</span>
        </a>
      </div>

      <div class="presentations-section">
        <h2>Presentations</h2>
        <ul class="presentations-list">
          <li>
            <a href={`${base}/presentations/pir/`}>Sharded PIR Design for Ethereum State</a>, EthCC &middot; <a href="https://efdn.notion.site/Stateless-Summit-2a4d9895554180309018e471f19efda9" target="_blank" rel="noopener noreferrer">Stateless Summit</a> &middot; 2026
          </li>
          <li>
            <a href={`${base}/presentations/torjs/`}>Network-level Privacy for Ethereum RPC Traffic</a>, EthCC &middot; <a href="https://efdn.notion.site/Stateless-Summit-2a4d9895554180309018e471f19efda9" target="_blank" rel="noopener noreferrer">Stateless Summit</a> &middot; 2026
          </li>
        </ul>
      </div>
    </div>
  </section>
</Base>

<style>
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .doc-tile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-card);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .doc-tile:hover {
    color: inherit;
    border-color: var(--border-hover);
    box-shadow: 0 4px 16px var(--shadow-card);
    transform: translateY(-2px);
  }
  .doc-tile-icon {
    color: var(--purple);
    margin-bottom: 0.25rem;
  }
  .doc-tile h2 {
    font-size: 1.3rem;
    margin: 0;
  }
  .doc-tile p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0;
    flex-grow: 1;
  }
  .doc-tile-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--link);
    margin-top: 0.5rem;
  }
  .doc-tile:hover .doc-tile-link { color: var(--link-hover); }

  .presentations-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .presentations-section h2 {
    font-size: 1.1rem;
    color: var(--text-muted);
    font-weight: 500;
    margin: 0 0 0.75rem 0;
  }
  .presentations-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .presentations-list li {
    padding: 0.4rem 0;
  }
  .presentations-list a {
    font-size: 0.95rem;
    color: var(--link);
    text-decoration: none;
  }
  .presentations-list a:hover {
    color: var(--link-hover);
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .docs-grid { grid-template-columns: 1fr; }
  }
</style>
