---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const entries = await getCollection('feed');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.description}>
  <article class="section">
    <div class="container">
      <div class="post-header">
        <a href={`${base}/feed`} class="back-link">&larr; Feed</a>
        <div class="post-meta">
          <span class="post-type">{entry.data.type}</span>
          {entry.data.event && <span class="post-event">{entry.data.event}</span>}
          <time datetime={entry.data.date.toISOString()}>
            {entry.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="meta-sep">&middot;</span>
          <span>{entry.data.author}</span>
        </div>
        <h1>{entry.data.title}</h1>
        <div class="post-tags">
          {entry.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>

      <div class="prose post-content">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .back-link:hover {
    color: var(--link);
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .post-type {
    font-weight: 500;
    color: var(--purple);
  }
  .post-event {
    color: var(--text-muted);
  }
  .meta-sep {
    color: var(--text-dim);
  }

  .post-header h1 {
    margin-bottom: 0.75rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    font-size: 0.7rem;
    color: var(--text-dim);
    padding: 0.15em 0.5em;
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .post-content {
    max-width: 720px;
  }
  .post-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .post-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }
  .post-content :global(blockquote) {
    border-left: 3px solid var(--purple);
    padding-left: 1.25rem;
    color: var(--text-muted);
    margin: 1.5rem 0;
    font-style: italic;
  }
</style>
