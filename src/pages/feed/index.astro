---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const entries = (await getCollection('feed'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const types = [...new Set(entries.map((e) => e.data.type))].sort();
---

<Base title="Feed" description="Research, engineering notes, talks, and updates from the Private Reads team.">
  <section class="section">
    <div class="container">
      <h1>Feed</h1>

      <!-- Filter bar -->
      <div class="filter-bar" id="filter-bar">
        <button class="filter-btn active" data-type="all">All</button>
        {types.map((type) => (
          <button class="filter-btn" data-type={type}>{type}</button>
        ))}
      </div>

      {entries.length === 0 && (
        <div class="card empty-state">
          <p>Nothing in the feed yet. Check back soon.</p>
        </div>
      )}

      <div class="feed-list" id="feed-list">
        {entries.map((entry) => (
          <a href={`${base}/feed/${entry.id}`} class="card feed-card" data-type={entry.data.type}>
            <div class="feed-meta">
              <span class="feed-type">{entry.data.type}</span>
              {entry.data.event && <span class="feed-event">{entry.data.event}</span>}
              <time datetime={entry.data.date.toISOString()}>
                {entry.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </div>
            <h2 class="feed-title">{entry.data.title}</h2>
            <p class="feed-desc">{entry.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  const bar = document.getElementById('filter-bar');
  const list = document.getElementById('feed-list');
  if (bar && list) {
    const buttons = bar.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = list.querySelectorAll<HTMLElement>('.feed-card');

    function activateFilter(type: string) {
      buttons.forEach((b) => b.classList.remove('active'));
      const target = Array.from(buttons).find((b) => b.dataset.type === type);
      if (target) target.classList.add('active');
      else buttons[0]?.classList.add('active'); // fallback to "All"

      cards.forEach((card) => {
        if (type === 'all' || card.dataset.type === type) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    }

    // Check URL for ?type= param and pre-activate filter
    const params = new URLSearchParams(window.location.search);
    const initialType = params.get('type');
    if (initialType) {
      activateFilter(initialType);
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.type || 'all';
        activateFilter(type);
        // Update URL without reload
        const url = new URL(window.location.href);
        if (type === 'all') {
          url.searchParams.delete('type');
        } else {
          url.searchParams.set('type', type);
        }
        history.replaceState(null, '', url.toString());
      });
    });
  }
</script>

<style>
  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 560px;
    margin-bottom: 1.5rem;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2rem;
  }
  .filter-btn {
    font-family: inherit;
    font-size: 0.8rem;
    font-weight: 400;
    padding: 0.3em 0.85em;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s var(--ease);
  }
  .filter-btn:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }
  .filter-btn.active {
    background: var(--purple-light);
    border-color: var(--purple);
    color: var(--purple);
  }

  /* Feed list */
  .feed-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feed-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
    color: inherit;
    border: none;
  }
  .feed-card:hover { color: inherit; border: none; }

  .feed-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  .feed-type {
    font-weight: 500;
    color: var(--purple);
  }
  .feed-event {
    color: var(--text-muted);
  }

  .feed-title {
    font-size: 1.25rem;
    margin: 0;
    transition: color 0.2s var(--ease);
  }
  .feed-card:hover .feed-title {
    color: var(--link);
  }

  .feed-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.6;
  }


  .empty-state {
    text-align: center;
    padding: 3rem;
  }
  .empty-state p {
    color: var(--text-muted);
    margin: 0;
  }
</style>
