---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Code" description="Open-source code from the Private Reads team — PIR specs and TorJS.">
  <section class="section">
    <div class="container">
      <h1>Code</h1>

      <div class="code-section">
        <h2>PIR Specs</h2>
        <p class="prose">
          Executable specs of <a href="https://eprint.iacr.org/2024/318" target="_blank" rel="noopener noreferrer">Plinko</a> &amp; <a href="https://doi.org/10.1145/3658644.3690266" target="_blank" rel="noopener noreferrer">RMS24</a> schemes.
        </p>
        <a href="https://github.com/keewoolee/rms24-plinko-spec" class="repo-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          keewoolee/rms24-plinko-spec
        </a>

        <p class="prose" style="margin-top: 1.5rem;">
          Reference specification for the <a href="https://eprint.iacr.org/2025/2074" target="_blank" rel="noopener noreferrer">VIA</a> PIR scheme — covering VIA, VIA-B, and VIA-CB variants with reusable lattice primitives.
        </p>
        <a href="https://github.com/turanzv/via-spec" class="repo-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          turanzv/via-spec
        </a>
      </div>

      <!-- <div class="code-section">
        <h2>LeanPIR</h2>
        <p class="prose">
          Our in-house GPU-optimized and doubly-stateless PIR scheme. Preliminary results indicate
          ~30 ms server runtime for a 32 GB database with sub-second preprocessing
          and &lt;100 KB communication.
        </p>
        <p class="prose"><em>Paper and code coming out 2Q26.</em></p>
      </div> -->

      <div class="code-section">
        <h2>TorJS</h2>
        <p class="prose">
          <a href="https://gitlab.torproject.org/tpo/core/arti">Arti</a> — the <a href="https://www.torproject.org/">Tor Project</a>'s
          Rust client — <a href="https://tor-js-gateway.voltrevo.com/" target="_blank" rel="noopener noreferrer">embedded</a> in-browser by <a href={`${base}/feed/embedding-arti-in-the-browser`}>adapting and compiling</a> it to WASM so any wallet, frontend, or dApp can route traffic through Tor
          via a <code>fetch()</code>-compatible API. Built in collaboration with the Tor Project; upstream merge in progress.
          <a href={`${base}/feed/embedding-arti-in-the-browser`}>Technical post</a> / <a href={`${base}/docs/torjs`}>Integration docs</a> (see also: <a href={`${base}/presentations/torjs/`}>high-level overview</a>).
        </p>
        <a href="https://github.com/voltrevo/arti" class="repo-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          voltrevo/arti
          <span class="branch">wasm-arti-client</span>
        </a>
        <a href="https://github.com/privacy-ethereum/tor-js-gateway" class="repo-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          privacy-ethereum/tor-js-gateway
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .code-section {
    margin-bottom: 2.5rem;
  }
  .code-section h2 {
    margin-bottom: 0.5rem;
  }
  .code-section p {
    max-width: 640px;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .repo-link + .repo-link {
    margin-top: 0.6rem;
    margin-left: 0.6rem;
  }
  .repo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text);
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .repo-link:hover {
    color: var(--text);
    border-color: var(--border-hover);
    box-shadow: 0 2px 8px var(--shadow-card);
  }
  .branch {
    font-size: 0.78rem;
    color: var(--text-dim);
    padding: 0.1em 0.5em;
    background: var(--purple-light);
    border-radius: 4px;
  }
</style>
