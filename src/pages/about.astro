---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="About" description="About the Private Reads team — privacy-preserving reads for Ethereum.">
  <!-- Intro -->
  <section class="section">
    <div class="container prose">
      <h1>About</h1>
      <p>
        Private Reads is a team within the
        <a href="https://ethereum.foundation">Ethereum Foundation</a>
        focused on making privacy-preserving reads of Ethereum data practical and accessible.
        We build tools and solutions that protect <em>what</em> users are reading from
        Ethereum's state and <em>who</em> is doing the reading — so that wallets, frontends,
        and dApps can query Ethereum without leaking metadata to servers.
      </p>
      <p>
        Our work spans <a href="https://notes.ethereum.org/U9xM4VOPR9isPK7lOZJUQg?view">Private Information Retrieval</a>,
        <a href="https://pse.dev/projects/tor-js">network-level anonymization</a>,
        <a href="https://pse.dev/projects/verifiable-ubt">verifiable state infrastructure</a>,
        and ecosystem activation through <a href="https://efdn.notion.site/PAPs-0cbd98955541825296e201936c5361f2">targeted grants</a>.
      </p>
    </div>
  </section>

  <!-- Team -->
